# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# Groq API Key — get yours free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model — llama3-8b-8192 is fast and free. Other options:
# llama3-70b-8192 (more capable, still free)
# mixtral-8x7b-32768 (large context window)
GROQ_MODEL=llama-3.3-70b-versatile

# ChromaDB — local persistent vector store (no setup needed)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=erp_docs

# RAG chunking settings
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Path to your documents folder
DOCS_DIR=./data/sample_docs
